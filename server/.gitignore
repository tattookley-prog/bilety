# Игнорируем БД лицензий — она содержит хэши паролей и не должна попасть в git
licenses.db
*.db

# Игнорируем папку с приватными скриптами — настоящие .sh хранятся только на сервере
private_scripts/*
!private_scripts/.gitkeep

# Питоновские артефакты
__pycache__/
*.pyc
*.pyo
*.egg-info/
.venv/
venv/
